{
  "name": "TypeUI Design.md Generator",
  "version": "1.0.5",
  "description": "Sketch plugin that extracts styles and generates editable DESIGN.md and SKILL.md drafts based on TypeUI.",
  "homepage": "https://github.com/bergside/design-md-sketch",
  "author": "Bergside",
  "repository": {
    "type": "git",
    "url": "https://github.com/bergside/design-md-sketch.git"
  },
  "engines": {
    "sketch": ">=3.0"
  },
  "skpm": {
    "name": "TypeUI",
    "manifest": "src/manifest.json",
    "main": "design-md-sketch.sketchplugin",
    "assets": [
      "assets/**/*"
    ]
  },
  "scripts": {
    "build": "skpm-build",
    "watch": "skpm-build --watch",
    "start": "skpm-build --watch",
    "postinstall": "npm run build && skpm-link",
    "skpm:login": "skpm login",
    "publish:help": "skpm publish --help",
    "publish:patch": "skpm publish patch",
    "publish:minor": "skpm publish minor",
    "publish:major": "skpm publish major"
  },
  "devDependencies": {
    "@skpm/builder": "^0.7.4",
    "@skpm/extract-loader": "^2.0.2",
    "css-loader": "^3.2.0",
    "html-loader": "^0.5.5",
    "skpm": "1.3.3"
  },
  "resources": [
    "resources/**/*.js"
  ],
  "dependencies": {
    "@babel/runtime": "^7.27.1",
    "sketch-module-web-view": "^3.1.4"
  }
}
